{
  "name": "sistemaagencia",
  "version": "1.0.0",
  "description": "",
  "main": "electron-main.js",
  "build": {
    "appId": "com.agencia.sistema",
    "productName": "SistemaAgencia",
    "files": [
      "backend/**/*",
      "backend/node_modules/**/*",
      "frontend/dist/**/*",
      "electron-main.js",
      "preload.js",
      "offline.html",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": false
    },
    "asar": false
  },
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && node server.js",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:dev:electron\"",
    "build:frontend": "cd frontend && npm run build",
    "pack": "npm run build:frontend && electron-builder --dir",
    "dist": "npm run build:frontend && electron-builder",
    "dist:win": "npm run build:frontend && electron-builder --win",
    "dist:mac": "npm run build:frontend && electron-builder --mac",
    "dist:linux": "npm run build:frontend && electron-builder --linux"
  },
  "keywords": [],
  "author": "Ameli Reyes",
  "license": "MIT",
  "dependencies": {
    "wait-port": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.4.0"
  }
}